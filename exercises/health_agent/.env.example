# Copie este arquivo para .env e preencha com sua chave real.
# Nunca commite o arquivo .env (ele já está no .gitignore).

# Chave da API do OpenRouter — crie a sua em https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Opcional: modelo gratuito a usar. Veja modelos free em
# https://openrouter.ai/models?max_price=0
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Opcional: limite de caracteres por mensagem do usuário
# MAX_INPUT_CHARS=2000

# Opcional: nome exibido no título da aplicação
# APP_NAME=Agente de Saude
